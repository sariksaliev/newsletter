# Database (sqlite for dev, postgres for prod)
DATABASE_URL=sqlite+aiosqlite:///./data/outreach.db

# Telegram API — одна пара на весь проект: https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Anthropic (dialog bot + LLM-профили)
ANTHROPIC_API_KEY=sk-ant-your-key-here
DIALOG_MODEL=claude-sonnet-4-20250514

# OpenAI (optional: voice transcription)
OPENAI_API_KEY=sk-your-openai-key-here

# Sales notifications — бот + ID группы/чата
SALES_TELEGRAM_BOT_TOKEN=
SALES_TELEGRAM_CHAT_ID=

# App
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-in-production

# Warmup
WARMUP_DAYS=3
WARMUP_CHANNELS_PER_DAY=5
WARMUP_MESSAGES_PER_DAY=6
WARMUP_REACTIONS_PER_DAY=5
WARMUP_BROWSE_MESSAGES=15

# Outreach
OUTREACH_DAILY_LIMIT_PER_ACCOUNT=4
OUTREACH_MIN_DELAY_SEC=45
OUTREACH_MAX_DELAY_SEC=180
DELIVERY_TARGET_PCT=85

# Proxy
MAX_ACCOUNTS_PER_PROXY=3

# Profile edits anti-correlation
MAX_PROFILE_EDITS_PER_HOUR=5
PROFILE_EDIT_JITTER_MIN_SEC=900
PROFILE_EDIT_JITTER_MAX_SEC=7200
